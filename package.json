    "test:hud-critical": "npm run compile:esm && node tests/hud-critical-state-feedback-check.mjs",
    "test:bomb-preview": "npm run compile:esm && node tests/bomb-preview-toggle-check.mjs",
    "test:bot-powerup": "npm run compile:esm && node tests/bot-powerup-priority-check.mjs",
    "test:bot-survival": "npm run compile:esm && node tests/bot-survival-10s-check.mjs",
    "test:bot-direction": "npm run compile:esm && node tests/bot-direction-stability-check.mjs",
    "test:bot-target": "npm run compile:esm && node tests/bot-target-selection-check.mjs",
    "test:bomb-range": "npm run compile:esm && node tests/bomb-range-snapshot-check.mjs",
    "test:bomb-hit-window": "npm run compile:esm && node tests/bomb-hit-window-check.mjs",
    "test:bomb-chain": "npm run compile:esm && node tests/bomb-chain-reaction-check.mjs",
    "test:bomb-push": "npm run compile:esm && node tests/bomb-push-check.mjs",
    "test:demolition-combo": "npm run compile:esm && node tests/demolition-combo-drop-check.mjs",
    "test:autobot-codex-e2e": "node tests/autobot-codex-e2e.mjs",
    "test:shield": "npm run compile:esm && node tests/shield-powerup-check.mjs",
    "test:shield-breakaway": "npm run compile:esm && node tests/shield-breakaway-burst-check.mjs",
    "test:pickup-sprint": "npm run compile:esm && node tests/pickup-sprint-check.mjs",
    "test:shield-block-sfx": "npm run compile:esm && node tests/shield-block-sfx-check.mjs",
    "test:powerup-hud": "npm run compile:esm && node tests/powerup-hud-slots-check.mjs",
    "test:powerup-drop-rate": "npm run compile:esm && node tests/powerup-drop-rate-check.mjs",
    "test:player-sprite": "npm run compile:esm && node tests/player-sprite-render-check.mjs",
    "test:killer-bee-ult": "npm run compile:esm && node tests/killer-bee-ult-dash-check.mjs",
    "test:crocodilo-ult": "npm run compile:esm && node tests/crocodilo-ult-emerald-surge-check.mjs",
    "test:nico-ult": "npm run compile:esm && node tests/nico-ult-arcane-beam-check.mjs",
    "test:ranni-ult": "npm run compile:esm && node tests/ranni-ult-ice-blink-check.mjs",
    "test:sprite-trim": "npm run compile:esm && node tests/sprite-trim-cache-check.mjs",
    "test:round-outcome": "npm run compile:esm && node tests/round-outcome-pause-check.mjs",
    "test:remote": "npm run compile:esm && node tests/remote-detonation-check.mjs",
    "test:pixellab-roster": "node tests/pixellab-roster-check.mjs",
    "test:pixellab-orchestrator": "node tests/pixellab-orchestrator-check.mjs",
    "test:pixellab-pack": "node tests/pixellab-pack-spec-check.mjs"
