{
  "name": "autowebgame",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run_local_dev.mjs",
    "dev:frontend": "vite",
    "build": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "build:cloudflare": "npm run build",
    "dev:cloudflare": "npm run build && node ./node_modules/wrangler/bin/wrangler.js dev --local",
    "deploy:cloudflare": "npm run build && node ./node_modules/wrangler/bin/wrangler.js deploy",
    "serve:oracle": "npm run build && node scripts/run_oracle_local_server.mjs",
    "serve:online": "npm run build && node ./node_modules/wrangler/bin/wrangler.js dev --local --port 8787",
    "serve:online:legacy-relay": "node scripts/online_server.mjs",
    "preview": "vite preview",
    "airtest:doctor": "powershell -ExecutionPolicy Bypass -File scripts/airtest-assets.ps1 doctor",
    "airtest:match": "powershell -ExecutionPolicy Bypass -File scripts/airtest-assets.ps1 match",
    "airtest:scan": "powershell -ExecutionPolicy Bypass -File scripts/airtest-assets.ps1 scan-dir",
    "pixellab:run": "node scripts/pixellab_orchestrator.mjs run --spec configs/pixellab-pack.v1.json",
    "pixellab:status": "node scripts/pixellab_orchestrator.mjs status --spec configs/pixellab-pack.v1.json",
    "sync:pixellab": "node scripts/import_pixellab_characters.mjs",
    "compile:esm": "node node_modules/typescript/bin/tsc -p tsconfig.runtime.json && node tests/patch-esm-imports.mjs",
    "test:bot": "npm run compile:esm && node tests/bot-intel-check.mjs",
    "test:character-menu": "npm run compile:esm && node tests/character-selection-menu-check.mjs",
    "test:bot-own-blast": "npm run compile:esm && node tests/bot-own-blast-escape-check.mjs",
    "test:bot-remote": "npm run compile:esm && node tests/bot-remote-detonation-check.mjs",
    "test:bot-opening": "npm run compile:esm && node tests/bot-opening-discipline-check.mjs",
    "test:menu-bot-fill": "npm run compile:esm && node tests/menu-bot-fill-check.mjs",
    "test:arena-theme-selection": "npm run compile:esm && node tests/arena-theme-selection-check.mjs",
    "test:input-alias": "npm run compile:esm && node tests/local-input-alias-check.mjs",
    "test:input-visibility": "npm run compile:esm && node tests/input-visibility-clear-check.mjs",
    "test:game-visibility-pause": "npm run compile:esm && node tests/game-visibility-auto-pause-check.mjs",
    "test:input-page-scroll": "npm run compile:esm && node tests/input-page-scroll-check.mjs",
    "test:local-match-chrome": "npm run compile:esm && node tests/local-match-chrome-check.mjs",
    "test:input": "npm run compile:esm && node tests/input-transition-check.mjs",
    "test:arena-runtime": "npm run compile:esm && node tests/arena-runtime-contract-check.mjs",
    "test:spawn": "npm run compile:esm && node tests/spawn-escape-check.mjs",
    "test:online-4p": "npm run compile:esm && node tests/online-four-player-check.mjs",
    "test:matchmaking-state": "npm run compile:esm && node tests/matchmaking-session-state-check.mjs",
    "test:lobby-rules": "npm run compile:esm && node tests/lobby-rules-check.mjs",
    "test:lobby-disconnected-actions": "npm run compile:esm && node tests/lobby-disconnected-actions-check.mjs",
    "test:session-return-brief": "npm run compile:esm && node tests/session-return-brief-check.mjs",
    "test:room-invite-link": "npm run compile:esm && node tests/session-room-invite-link-check.mjs",
    "test:room-code-enter-submit": "npm run compile:esm && node tests/room-code-enter-submit-check.mjs",
    "test:account-username": "npm run compile:esm && node tests/account-username-validation-check.mjs",
    "test:match-result-shortcuts": "npm run compile:esm && node tests/match-result-shortcuts-check.mjs",
    "test:ui-storage-fallback": "npm run compile:esm && node tests/ui-storage-fallback-check.mjs",
    "test:i18n-storage-guard": "npm run compile:esm && node tests/i18n-storage-guard-check.mjs",
    "test:touch-focus-css": "node tests/touch-focus-css-check.mjs",
    "test:roster-sync": "npm run compile:esm && node tests/character-roster-manifest-sync-check.mjs",
    "test:server-character-skill": "npm run compile:esm && node tests/server-character-skill-mapping-check.mjs",
    "test:online-character-selection": "npm run compile:esm && node tests/online-character-selection-index-check.mjs",
    "test:online-audio": "npm run compile:esm && node tests/online-audio-bridge-check.mjs",
    "test:online-input-latch": "npm run compile:esm && node tests/online-input-latching-check.mjs",
    "test:online-skill-reconcile": "npm run compile:esm && node tests/online-skill-reconcile-check.mjs",
    "test:skill-contract": "npm run compile:esm && node tests/character-skill-contract-check.mjs",
