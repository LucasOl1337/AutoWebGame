      "key": "arena-tiles",
      "batch": "tiles",
      "enabled": true,
      "kind": "tiles-pro",
      "tool": "create_tiles_pro",
      "responseIdKeys": [
        "id",
        "tile_id",
        "result.id",
        "result.tile_id"
      ],
      "submit": {
        "path": "/create-tiles-pro",
        "method": "POST",
        "body": {
          "description": "1). heroic fantasy stone arena floor with rich blue-gray shading and subtle runic wear 2). lighter combat lane floor tile with carved slab direction and cleaner highlights 3). glowing arcane spawn floor tile with restrained gold-blue rune center 4). heavy fortified wall tile with readable top-down depth, carved stone lip and crisp silhouette 5). breakable wooden crate tile with iron braces, cracks and readable shape 6). optional accent floor tile with moss and engraved edge detail",
          "tile_type": "square_topdown",
          "tile_size": 32,
          "tile_view": "low top-down",
          "outline_mode": "outline"
        }
      },
      "poll": {
        "pathTemplate": "/tiles-pro/{remoteId}"
      },
      "outputs": [
        {
          "key": "floor-base",
          "sourcePaths": [
