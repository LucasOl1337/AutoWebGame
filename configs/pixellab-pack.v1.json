            "data.storage_urls.tile_0",
            "data.b2_urls.tile_0",
            "data.urls.tile_0",
            "data.result.b2_urls.tile_0"
          ],
          "targetPath": "public/assets/tiles/floor-base.png"
        },
        {
          "key": "floor-lane",
          "sourcePaths": [
